{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["../../apps/taskly-app/app/*"]
		},
		"plugins": [{ "name": "next" }],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": true,
		"jsx": "react-jsx",
		"noEmit": true
	}
}
