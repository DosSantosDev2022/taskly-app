generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                String    @id @default(cuid())
  name              String
  surname           String? // optional
  description       String? // optional
  email             String    @unique
  emailVerified     DateTime? @map("email_verified")
  verificationToken String?   @unique
  password          String? // optional
  image             String? // optional
  coverImage        String? // optional
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projects       Project[]
  tasks          Task[]
  comments       Comment[]
  notifications  Notification[]
  timeTracking   TimeTracking[]
  sharedProjects SharedProject[]
  subscription   Subscription?
  TeamMember     TeamMember[]

  accounts           Account[]
  sessions           Session[]
  PasswordResetCode  PasswordResetCode[]
  PasswordResetToken PasswordResetToken[]

  @@index([email])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Status do Projeto (Enum)
enum ProjectStatus {
  active
  archived
}

enum ClientStatus {
  active
  inactive
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  ownerId     String
  teamId      String?
  clientId    String?
  owner       User          @relation(fields: [ownerId], references: [id])
  team        Team?         @relation(fields: [teamId], references: [id])

  tasks      Task[]
  client     Client?         @relation(fields: [clientId], references: [id])
  comments   Comment[]
  sharedWith SharedProject[]

  @@index([ownerId])
  @@index([clientId])
}

model Client {
  id        String        @id @default(uuid())
  name      String
  email     String?       @unique
  phone     String?
  address   String?
  zipcode   String?
  state     String?
  city      String?
  status    ClientStatus?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  projects Project[]
}

// Status da Tarefa (Enum)
enum TaskStatus {
  to_do
  in_progress
  done
}

// Prioridade da Tarefa (Enum)
enum TaskPriority {
  low
  medium
  high
  urgent
}

model Task {
  id         String       @id @default(uuid())
  title      String
  desciption String?
  status     TaskStatus[]
  priority   TaskPriority
  dueDate    DateTime
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  projectId  String
  ownerId    String
  teamId     String
  project    Project      @relation(fields: [projectId], references: [id])
  owner      User         @relation(fields: [ownerId], references: [id])
  team       Team         @relation(fields: [teamId], references: [id])

  comments     Comment[]
  tags         TaskTag[]
  subTasks     SubTask[]
  TimeTracking TimeTracking[]

  @@index([projectId, ownerId])
}

model SubTask {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id])
}

// Papel no Compartilhamento (Enum)
enum Role {
  viewer
  editor
}

model SharedProject {
  id        String  @id @default(uuid())
  userId    String
  projectId String
  role      Role
  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  @@index([userId, projectId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  Project   Project? @relation(fields: [projectId], references: [id])
  projectId String?
}

model TaskTag {
  id     String @id @default(uuid())
  name   String
  color  String @default("#000000")
  taskId String
  task   Task   @relation(fields: [taskId], references: [id])
}

// Tipo da Notificação (Enum)
enum NotificationType {
  task_due
  new_comment
  task_assignment
}

// Tipo do Item Relacionado (Enum)
enum RelatedType {
  task
  project
  comment
}

model Notification {
  id          String           @id @default(uuid())
  message     String
  type        NotificationType
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())
  expiresAt   DateTime?
  userId      String
  relatedId   String
  relatedType RelatedType
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId, relatedId])
}

model TimeTracking {
  id        String   @id @default(uuid())
  duration  Int // em segundos
  startedAt DateTime
  userId    String
  taskId    String? // opcional
  user      User     @relation(fields: [userId], references: [id])
  task      Task?    @relation(fields: [taskId], references: [id])
}

// Plano de Assinatura (Enum)
enum SubscriptionPlan {
  free
  pro
  premium
}

model Subscription {
  id        String           @id @default(uuid())
  userId    String           @unique
  plan      SubscriptionPlan
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model Team {
  id              String       @id @default(uuid())
  teamName        String?
  teamDescription String?
  teamAvatarImage String? // opitional
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  projects        Project[]
  members         TeamMember[]
  Task            Task[]
}

model TeamMember {
  id       String   @id @default(uuid())
  userId   String
  role     String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  team     Team     @relation(fields: [teamId], references: [id])
  teamId   String

  @@index([userId, teamId])
}
